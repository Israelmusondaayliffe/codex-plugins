{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/capability-operator/route-schema.json",
  "title": "Capability Router Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "primary_route",
    "route_type",
    "plugin",
    "skill",
    "reason",
    "load_order",
    "companions",
    "excluded_routes",
    "verification_needed"
  ],
  "properties": {
    "primary_route": {"type": "string", "pattern": "^[a-z0-9-]+:[a-z0-9-]+$"},
    "route_type": {"enum": ["plugin-router", "plugin-skill", "standalone-skill"]},
    "plugin": {"type": ["string", "null"], "pattern": "^[a-z0-9-]+$"},
    "skill": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "reason": {"type": "string", "minLength": 1},
    "load_order": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "companions": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "excluded_routes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "verification_needed": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
  }
}
