        "id": "budget-pressure-collapse",
        "trigger": "budget-consumption-exceeds-progress",
        "thresholds": [
          50,
          75,
          90
        ],
        "pattern": "collapse_fanout",
        "riskLevel": "low",
        "approvalRequired": false,
        "targets": [
          "newsletter-distribution",
          "social-distribution",
          "community-distribution"
        ],
        "primitiveOperations": [
          "disable_edge",
          "disable_node"
        ],
        "reason": "Collapse redundant optional distribution fan-out before hard limits are reached."
      },
      {
        "id": "repeated-failure-reviewer",
        "trigger": "same-node-fails-twice",
        "failureCount": 2,
        "pattern": "add_reviewer",
        "riskLevel": "low",
        "approvalRequired": false,
        "targets": [
          "researcher",
          "article-builder"
        ],
        "primitiveOperations": [
          "add_node",
          "add_edge"
        ],
        "reason": "Add an independent internal reviewer after repeated node failure."
      }
    ]
