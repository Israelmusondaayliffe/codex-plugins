{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "minimum_confidence", "max_auto_score", "max_source_lines", "max_source_bytes", "max_inline_data_bytes", "inactive_days", "required_controls", "unavailable_is_pass", "self_approval_for_elevated_release"],
  "properties": {
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "minimum_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "max_auto_score": {"type": "integer", "minimum": 0, "maximum": 16},
    "max_source_lines": {"type": "integer", "minimum": 1},
    "max_source_bytes": {"type": "integer", "minimum": 1},
    "max_inline_data_bytes": {"type": "integer", "minimum": 1},
    "inactive_days": {"type": "integer", "minimum": 1},
    "required_controls": {"type": "array", "minItems": 35, "uniqueItems": true, "items": {"type": "string"}},
    "unavailable_is_pass": {"const": false},
    "self_approval_for_elevated_release": {"const": false}
  },
  "additionalProperties": false
}
